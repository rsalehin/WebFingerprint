# Backend server port
PORT=3020

# WebSocket port (must match PORT in development)
VITE_WS_PORT=3020

# Anthropic API key — required for AI-powered profiling and ad auction simulation
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Redis URL — optional; enables AI response caching and unique visitor tracking
REDIS_URL=redis://localhost:6379
